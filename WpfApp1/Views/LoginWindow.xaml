<Window x:Class="VendingFranchisee.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Личный кабинет франчайзера" 
                      FontSize="24" FontWeight="Bold" 
                      HorizontalAlignment="Center" Margin="0,0,0,30"
                      Foreground="#2C3E50"/>

            <TextBlock Text="Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Height="35" Margin="0,0,0,15" 
                    FontSize="14" Padding="5"/>

            <TextBlock Text="Пароль:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,20" 
                        FontSize="14" Padding="5"/>

            <Button Content="Войти" Click="BtnLogin_Click" 
                   Height="40" FontSize="16" FontWeight="Bold"
                   Background="#3498DB" Foreground="White"
                   BorderThickness="0" Margin="0,0,0,10"/>

            <TextBlock x:Name="lblError" Foreground="#E74C3C" 
                      Margin="0,10,0,0" Visibility="Collapsed"
                      TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>