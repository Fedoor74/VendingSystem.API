<Window x:Class="VendingFranchisee.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет франчайзера" Height="700" Width="1200" 
        WindowState="Maximized"
        Background="#ECF0F1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="ФРАНЧАЙЗЕР" Foreground="White" 
                              FontSize="20" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <Button Content="📊 Главная" Click="BtnHome_Click" 
                           Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="️ Монитор ТА" Click="BtnMonitor_Click" 
                           Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="⚙️ Администрирование" Click="BtnAdmin_Click" 
                           Style="{StaticResource MenuButtonStyle}"/>

                    <Separator Margin="20,20" Background="#34495E"/>

                    <StackPanel Margin="20,0">
                        <Ellipse Width="60" Height="60" Fill="#95A5A6" 
                                HorizontalAlignment="Center"/>
                        <TextBlock x:Name="tbUserName" Foreground="White" 
                                  FontWeight="Bold" FontSize="14" 
                                  Margin="0,10,0,5" TextAlignment="Center"/>
                        <TextBlock x:Name="tbUserRole" Foreground="#BDC3C7" 
                                  FontSize="12" TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Область контента -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>