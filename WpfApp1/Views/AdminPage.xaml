<Page x:Class="VendingFranchisee.Desktop.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Администрирование ТА" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBox x:Name="txtFilter" Width="300" Height="30" 
                    Text="Фильтр по названию..." Padding="5"/>
            <Button Content="Применить" Click="BtnApplyFilter_Click" 
                   Width="100" Height="30" Margin="10,0,0,0"/>
            <Button Content="➕ Добавить ТА" Click="BtnAddMachine_Click" 
                   Width="120" Height="30" Margin="20,0,0,0"
                   Background="#27AE60" Foreground="White"/>
        </StackPanel>

        <!-- Таблица -->
        <DataGrid x:Name="dgMachines" Grid.Row="1" 
                 AutoGenerateColumns="False" 
                 IsReadOnly="True"
                 AlternatingRowBackground="#F2F2F2"
                 HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding MachineId}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Location}" Width="200"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="150"/>
                <DataGridTextColumn Header="Франчайзи" Binding="{Binding FranchiseeName}" Width="120"/>
                <DataGridTextColumn Header="Модем" Binding="{Binding ModemId}" Width="80"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Location}" Width="250"/>
                <DataGridTextColumn Header="В работе с" Binding="{Binding DateOfCommissioning, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="✏️ Редактировать" Click="MnuEdit_Click"/>
                    <MenuItem Header="🔌 Отвязать модем" Click="MnuUnbindModem_Click"/>
                    <MenuItem Header="🗑️ Удалить" Click="MnuDelete_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Page>